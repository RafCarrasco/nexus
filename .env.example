# Postgres
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://nexus:replace-me@localhost:5432/nexus?schema=public

# Vault master key (32 raw bytes, base64-encoded)
NEXUS_MASTER_KEY=base64-32-bytes

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=http://localhost:3000
NEXUS_ALLOWED_EMAIL_DOMAIN=procurementgarage.com

# Public hostname Traefik should route to nexus-web
NEXUS_HOST=nexus.example.com
