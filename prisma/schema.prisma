generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  connections  Connection[]
  uptimeChecks UptimeCheck[]
  aiProbes     AiProbe[]
}

model Connection {
  id              String     @id @default(cuid())
  name            String
  type            String
  credentials     Bytes
  status          String     @default("active")
  lastError       String?
  lastCollectedAt DateTime?
  ownerUserId     String
  workspaceId     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  resources       Resource[]
  ingestTokens    IngestToken[]
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
}

model IngestToken {
  id           String     @id @default(cuid())
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique
  name         String     @default("default")
  lastUsedAt   DateTime?
  createdAt    DateTime   @default(now())
  expiresAt    DateTime?

  @@index([connectionId])
}

model Resource {
  id            String         @id @default(cuid())
  connectionId  String
  externalId    String
  name          String
  kind          String
  region        String?
  metadata      Json
  clientId      String?
  allocationPct Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  connection    Connection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tenants       Tenant[]
  costSnapshots CostSnapshot[]
  activityLog   ActivityLog?
  incidents     Incident[]
  metrics       Metric[]
  thresholds    MetricThreshold[]

  @@unique([connectionId, externalId])
}

// User-defined numeric threshold on an ingested Metric. The runMetricEval collector
// evaluates each enabled rule against the latest Metric value within lookbackSec and
// opens/resolves a `metric_threshold:<name>` incident. This activates the Metric model
// (previously inert — ingest wrote metrics but nothing evaluated them) into a real
// early-warning signal: cpu>85, queue_depth>1000, error_rate>0.05, free_mem<10, etc.
model MetricThreshold {
  id          String    @id @default(cuid())
  resourceId  String
  resource    Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  metricName  String
  operator    String // 'gt' | 'gte' | 'lt' | 'lte' | 'eq'
  threshold   Decimal   @db.Decimal(18, 6)
  severity    String    @default("warn") // 'warn' | 'crit'
  lookbackSec Int       @default(3600)
  enabled     Boolean   @default(true)
  lastValue   Decimal?  @db.Decimal(18, 6)
  lastEvalAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([resourceId, metricName])
}

model Metric {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  name       String
  value      Decimal  @db.Decimal(18, 6)
  unit       String   @default("")
  timestamp  DateTime
  metadata   Json?
  ingestedAt DateTime @default(now())

  @@unique([resourceId, name, timestamp])
  @@index([resourceId, timestamp])
  @@index([name, timestamp])
}

model Tenant {
  id          String   @id @default(cuid())
  resourceId  String
  externalId  String
  displayName String
  clientId    String?
  resource    Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, externalId])
}

model CostSnapshot {
  id         String   @id @default(cuid())
  resourceId String
  date       DateTime
  amount     Decimal  @db.Decimal(12, 4)
  currency   String   @default("USD")
  source     String
  breakdown  Json?
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, date, source])
  @@index([date])
}

model ActivityLog {
  resourceId String    @id
  lastSeenAt DateTime?
  source     String
  updatedAt  DateTime  @updatedAt
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
}

model Incident {
  id            String       @id @default(cuid())
  resourceId    String?
  uptimeCheckId String?
  aiProbeId     String?
  type          String
  severity      String
  message       String
  openedAt      DateTime     @default(now())
  resolvedAt    DateTime?
  payload       Json?
  resource      Resource?    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  uptimeCheck   UptimeCheck? @relation(fields: [uptimeCheckId], references: [id], onDelete: Cascade)
  aiProbe       AiProbe?     @relation(fields: [aiProbeId], references: [id], onDelete: Cascade)

  @@index([resolvedAt, openedAt])
}

model UptimeCheck {
  id               String     @id @default(cuid())
  name             String
  url              String
  method           String     @default("GET")
  intervalSec      Int        @default(300)
  failThreshold    Int        @default(3)
  workspaceId      String?
  enabled          Boolean    @default(true)
  consecutiveFails Int        @default(0)
  lastStatus       String?
  lastError        String?
  lastLatencyMs    Int?
  lastCheckedAt    DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  incidents        Incident[]
  samples          UptimeSample[]
}

// Per-tick time-series for an uptime check: latency + outcome. Feeds the latency-trend
// degradation detector (p95 of recent OK samples vs 7-day median baseline → opens a
// `performance_degraded` warn incident before the service actually goes down) and the
// latency sparkline on the uptime page. Pruned by the retention job.
model UptimeSample {
  id            String      @id @default(cuid())
  uptimeCheckId String
  uptimeCheck   UptimeCheck @relation(fields: [uptimeCheckId], references: [id], onDelete: Cascade)
  ok            Boolean
  status        Int?
  latencyMs     Int?
  at            DateTime    @default(now())

  @@index([uptimeCheckId, at])
}

model AiProbe {
  id               String   @id @default(cuid())
  name             String
  url              String
  method           String   @default("POST")
  headers          Json? // { "Authorization": "Bearer ...", "Content-Type": "application/json" }
  bodyTemplate     String // JSON string with $PROMPT placeholder, e.g. {"messages":[{"role":"user","content":"$PROMPT"}]}
  prompt           String // the known input sent as $PROMPT
  responsePath     String? // optional dot-path to extract the answer from JSON response (e.g. "reply" or "choices.0.message.content"); empty = whole body text
  validationMode   String   @default("rule") // 'rule' | 'llm_judge'
  validationRule   String? // for rule mode: 'non_empty' | 'contains:<substr>'
  intervalSec      Int      @default(300)
  failThreshold    Int      @default(2)
  workspaceId      String?
  enabled          Boolean  @default(true)
  consecutiveFails Int      @default(0)
  lastStatus       String? // 'up' | 'down'
  lastError        String?
  lastResult       Json? // { ok, output, judgement? }
  lastCheckedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  workspace        Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  incidents        Incident[]
}

model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model NotificationChannel {
  id              String    @id @default(cuid())
  name            String
  type            String // 'webhook' | 'slack' | 'teams' | 'email'
  config          Bytes // encrypted: {url} for webhook/slack/teams, {host,port,user,pass,from,to} for email
  enabled         Boolean   @default(true)
  notifyOnOpen    Boolean   @default(true)
  notifyOnResolve Boolean   @default(true)
  lastError       String?
  lastFiredAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model AiConfig {
  id        String   @id // singleton row, id = 'singleton'
  provider  String   @default("anthropic") // 'anthropic' | 'openai' | 'gemini'
  model     String? // optional override; null = provider default
  config    Bytes // encrypted { apiKey }
  updatedAt DateTime @updatedAt
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  image         String?
  role          String     @default("member")
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime   @default(now())
  auditEntries  AuditLog[]
  savedFilters  SavedFilter[]
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  page      String
  name      String
  query     Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, page, name])
  @@index([userId, page])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    String
  payload   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

// Single-row liveness record for the collector loop itself. runAll stamps lastRunAt on
// every tick and lastSuccessAt when at least one connection collected without error.
// /api/health surfaces the age so a dead/hung scheduler (process OOM, uncaught throw,
// crashed cron) is detectable from outside — Nexus can monitor its own collector.
model CollectorHeartbeat {
  id              String    @id // 'singleton'
  lastRunAt       DateTime?
  lastSuccessAt   DateTime?
  connectionCount Int       @default(0)
  durationMs      Int?
  updatedAt       DateTime  @updatedAt
}
